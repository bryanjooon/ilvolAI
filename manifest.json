{
  "manifest_version": 3,
  "name": "ilvolAI",
  "version": "0.1.0",
  "description": "AI-powered load extraction for dispatchers",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "microphone",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://ilvolai-backend.*.workers.dev/*"
  ],
  "oauth2": {
    "client_id": "REPLACE_WITH_YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email",
      "profile"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ilvolAI"
  },
  "web_accessible_resources": [
    {
      "resources": ["panel.html", "panel.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "commands": {
    "toggle-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Toggle ilvolAI panel"
    }
  }
}
