{
  "manifest_version": 3,
  "name": "ilvolAI",
  "version": "0.0.1",
  "description": "AI-powered load extraction for dispatchers",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "microphone"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ilvolAI"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "commands": {
    "toggle-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Toggle ilvolAI panel"
    }
  }
}
